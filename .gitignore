__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.DS_Store
.codex
.ipynb_checkpoints/
.venv/
venv/

data/raw/*
data/reference/*
data/interim/*
data/processed/*
data/legacy/*

outputs/*
!outputs/README.md

# sim2real: the results ledger and reports are small and valuable — keep them
# in git (heavy artifacts like checkpoints/embeddings below stay ignored).
!outputs/sim2real/
outputs/sim2real/*
!outputs/sim2real/*/
outputs/sim2real/*/*
!outputs/sim2real/*/*.md
!outputs/sim2real/*/*.json
!outputs/sim2real/*/results.jsonl
!outputs/sim2real/*/l1/
outputs/sim2real/*/l1/*
!outputs/sim2real/*/l1/*.md
!outputs/sim2real/*/l1/*.json

third-party/*
!third-party/README.md

# sim2pipe: machine-specific paths stay local; ledger/report conventions
# mirror sim2real (outputs rules below).
configs/sim2pipe/paths.yaml
!outputs/sim2pipe/
outputs/sim2pipe/*
!outputs/sim2pipe/*/
outputs/sim2pipe/*/*
!outputs/sim2pipe/*/*.md
!outputs/sim2pipe/*/*.json
!outputs/sim2pipe/*/results.jsonl

# sim2pipe normalization ablation: keep ledger only
!outputs/sim2pipe_normabl/
outputs/sim2pipe_normabl/*
!outputs/sim2pipe_normabl/*/
outputs/sim2pipe_normabl/*/*
!outputs/sim2pipe_normabl/*/results.jsonl
